# =============================================================================
# Luminum – Docker Compose environment
# =============================================================================
# Copy this file to .env and set values before running: docker compose up -d
# Sensitive values (auth, API keys) should come from GitHub Secrets in CI;
# database and Redis are internal-only – set URLs/credentials on the server.
# =============================================================================

# --- Database (PostgreSQL – internal only; default used if not set) ---
POSTGRES_USER=luminum
POSTGRES_DB=luminum
POSTGRES_PORT=5432

# --- Redis (internal only; optional password set on deployment) ---
REDIS_PORT=6379

# --- Public URLs (replace with your domain in production) ---
APP_URL=http://localhost:3000
API_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:8080

# --- Exposed ports (optional overrides) ---
API_PORT=4000
DASHBOARD_PORT=3000
ANALYTICS_PORT=8080

# --- Authentication & security (required) ---
BETTER_AUTH_SECRET=generate_with_openssl_rand_hex_32
WEBHOOK_SECRET=shared_secret_for_webhooks
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Payments (Paystack) ---
PAYSTACK_SECRET=

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# --- Media (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OAuth (Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
