# =============================================================================
# Luminum – Docker Compose environment
# =============================================================================
# Copy this file to .env and set values before running: docker compose up -d
# Sensitive values (auth, API keys) should come from GitHub Secrets in CI;
# database and Redis are internal-only – set URLs/credentials on the server.
# =============================================================================

# --- Database (PostgreSQL – internal only; default used if not set) ---
POSTGRES_USER=luminum
POSTGRES_DB=luminum
POSTGRES_PORT=5432

# --- Redis (internal only; optional password set on deployment) ---
REDIS_PORT=6379

# --- Public URLs (replace with your domain in production) ---
APP_URL=http://localhost:3000
# Optional comma-separated browser origins allowed to call the API (dashboard, marketing site).
# If unset, APP_URL and NEXT_PUBLIC_APP_URL are merged (trailing slashes normalized).
# CORS_ORIGINS=http://localhost:3000,https://app.example.com
API_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:8080

# --- Exposed ports (optional overrides) ---
API_PORT=4000
DASHBOARD_PORT=3000
ANALYTICS_PORT=8080

# --- Authentication & security (required) ---
BETTER_AUTH_SECRET=generate_with_openssl_rand_hex_32
WEBHOOK_SECRET=shared_secret_for_webhooks
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Payments (Paystack) ---
PAYSTACK_SECRET=

# --- Object storage (MinIO; API uses S3-compatible client) ---
MINIO_ROOT_USER=luminum
MINIO_ROOT_PASSWORD=your_minio_secret
S3_BUCKET=luminum-storage
S3_REGION=us-east-1
# Optional: override in .env for local dev (API talks to MinIO on host)
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY_ID=luminum
# S3_SECRET_ACCESS_KEY=your_minio_secret

# --- OAuth (Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cron (HTTP jobs: DNS verify, analytics script verify, site audits) ---
# Set the same value in your scheduler (e.g. daily): curl -X POST -H "X-Cron-Secret: $CRON_SECRET" "$API_URL/api/cron/run-site-audits"
# Site audits require Redis + the audit-worker service processing the BullMQ queue.
# GitHub: add CRON_SECRET as a repository secret (same value) for .github/workflows/cron-site-audits.yml; optional repo variable PROD_API_URL.
# CRON_SECRET=
