# Base URL of the API (e.g. http://api:4000)
API_URL=
# Same secret as API; used to sign inbound webhook payloads
WEBHOOK_SECRET=
# Optional default From when not provided on send
# MAIL_FROM_DEFAULT=
# HTTP server port for /send and /health (default 8025)
# PORT_HTTP=8025
# SMTP server port for receiving mail (default 25; host must expose 25 for internet)
# PORT_SMTP=25
# DKIM signing: run this binary with "gen-dkim-key" to generate a key pair, then set:
# MAIL_DKIM_PRIVATE_KEY=<PEM string of the private key>
# MAIL_DKIM_SELECTOR=default
# Add the printed TXT value to DNS at <selector>._domainkey.<your-domain>
