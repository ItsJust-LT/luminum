# Express API Server
PORT=4000

# Public URL of the dashboard (for Better Auth baseURL, invite links, etc.)
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://...

# Better Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=

# Resend (email sending)
RESEND_API_KEY=

# In-repo mail service (apps/mail): base URL for send and health. In production set to http://mail:8025.
MAIL_APP_URL=http://mail:8025
# Optional: secret sent as X-Mail-Secret / Authorization to the mail app.
# MAIL_APP_SECRET=
# Default From header (e.g. Luminum <noreply@luminum.agency>).
# MAIL_FROM_DEFAULT=

# Org email DNS: customers point MX to mail.<their-domain> unless you override with MAIL_MX_HOST (single hostname for all orgs).
# MAIL_MX_HOST=
# Server public IPv4 — dashboard shows exact A + SPF lines; set on production host .env
# MAIL_SEND_IP=
# Optional: full DKIM TXT value to display in the dashboard (same public key as MAIL_DKIM_PRIVATE_KEY on apps/mail)
# MAIL_DKIM_DNS_VALUE=

# Webhooks (same value must be set for the mail service so it can sign inbound webhook payloads)
WEBHOOK_SECRET=

# Platform org email (inbox + send). Set to false to disable for all orgs (users see a generic message).
# EMAIL_SYSTEM_ENABLED=true

# Paystack
PAYSTACK_SECRET=

# Object storage (S3-compatible: MinIO or R2)
# MinIO (local/Docker): S3_ENDPOINT=http://localhost:9000, use MINIO_ROOT_* for keys
# R2: set S3_ENDPOINT to https://<ACCOUNT_ID>.r2.cloudflarestorage.com and R2 credentials as S3_* keys
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=luminum-storage
S3_REGION=us-east-1
# Public base URL for file links (e.g. https://api.example.com). If set, file URLs use /api/files/<key> under this base.
API_URL=

# Redis
REDIS_URL=
REDIS_PASSWORD=

# VAPID keys (push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics Go service URL (for form-notify and live-update)
ANALYTICS_URL=http://localhost:8080

# Public URL of this API server (for WebSocket URL returned to dashboard)
# If not set, defaults to http://localhost:4000
API_WS_URL=http://localhost:4000

# WhatsApp (whatsapp-web.js): path to Chromium when Puppeteer's bundled Chrome is missing (e.g. Docker).
# Set to /usr/bin/chromium or /usr/bin/chromium-browser. Dockerfile.api sets this for the image.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
