# Express API Server
PORT=4000

# Public URL of the dashboard (for Better Auth baseURL, invite links, etc.)
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://...

# Better Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=

# Resend (email sending)
RESEND_API_KEY=

# Default From header for system email if used (e.g. Luminum <noreply@example.com>).
# MAIL_FROM_DEFAULT=

# Server public IPv4 — branded custom-domain A record checks (Admin). SERVER_IP falls back to MAIL_SEND_IP if unset.
# MAIL_SEND_IP=
# SERVER_IP=

# Webhooks — HMAC secret for analytics and other signed callbacks.
WEBHOOK_SECRET=
# Optional: shared secret for POST /api/admin/logs/ingest.
# LOG_INGEST_SECRET=

# Platform org email (inbox + send). Set to false to disable for all orgs (users see a generic message).
# EMAIL_SYSTEM_ENABLED=true

# Amazon SES (required for org outbound; identity + DNS per org)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# EMAIL_SEND_SES_ORG_IDS=
# SES_CONFIGURATION_SET=
# SES_FROM_STRICT=true
# Lambda inbound webhook (same secret on Lambda env LUMINUM_SES_WEBHOOK_SECRET)
# SES_LAMBDA_INBOUND_SECRET=
# SES_INBOUND_LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789012:function:luminum-ses-inbound
# SES_RECEIPT_RULE_SET_NAME=luminum-ses-inbound
# SES_RECEIPT_RULE_NAME=luminum-forward-to-lambda
# Periodic DNS re-check in API process (ms); omit or 0 to disable
# EMAIL_DNS_PERIODIC_CHECK_MS=21600000
# Periodic scheduled Lighthouse site audits in API process (ms); omit or 0 to disable. Requires Redis + audit worker.
# SITE_AUDITS_PERIODIC_CHECK_MS=86400000

# Paystack
PAYSTACK_SECRET=

# Object storage (S3-compatible: MinIO or R2)
# MinIO (local/Docker): S3_ENDPOINT=http://localhost:9000, use MINIO_ROOT_* for keys
# R2: set S3_ENDPOINT to https://<ACCOUNT_ID>.r2.cloudflarestorage.com and R2 credentials as S3_* keys
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=luminum-storage
S3_REGION=us-east-1
# Public base URL for file links (e.g. https://api.example.com). If set, file URLs use /api/files/<key> under this base.
API_URL=

# Redis
REDIS_URL=
REDIS_PASSWORD=

# VAPID keys (push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics Go service URL (for form-notify and live-update)
ANALYTICS_URL=http://localhost:8080

# Public URL of this API server (for WebSocket URL returned to dashboard)
# If not set, defaults to http://localhost:4000
API_WS_URL=http://localhost:4000

# WhatsApp (whatsapp-web.js): path to Chromium when Puppeteer's bundled Chrome is missing (e.g. Docker).
# Set to /usr/bin/chromium or /usr/bin/chromium-browser. Dockerfile.api sets this for the image.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Protocol timeout for Puppeteer (ms). Default 600000. Increase if you see "callFunctionOn timed out".
# WHATSAPP_PROTOCOL_TIMEOUT_MS=600000
# Always-on reconnect: base delay (ms) and max backoff cap. Avoids hammering Puppeteer after crashes.
# WHATSAPP_ALWAYS_ON_RECONNECT_MS=5000
# WHATSAPP_ALWAYS_ON_MAX_BACKOFF_MS=1800000
# Admin incident log: min time between INIT_EXHAUSTED rows for the same org (ms). Default 600000.
# WHATSAPP_INIT_EXHAUSTED_LOG_COOLDOWN_MS=600000
# Do NOT set WHATSAPP_PUPPETEER_MINIMAL=true in production unless you must — it often causes unstable WhatsApp Web.
# WHATSAPP_PUPPETEER_MINIMAL=false
