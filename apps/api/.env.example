# Express API Server
PORT=4000

# Public URL of the dashboard (for Better Auth baseURL, invite links, etc.)
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://...

# Better Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=

# Resend (email sending)
RESEND_API_KEY=

# In-repo mail service (apps/mail): base URL for send and health. In production set to http://mail:8025.
MAIL_APP_URL=http://mail:8025
# Optional: secret sent as X-Mail-Secret / Authorization to the mail app.
# MAIL_APP_SECRET=
# Default From header (e.g. Luminum <noreply@luminum.agency>).
# MAIL_FROM_DEFAULT=

# Org email DNS: customers point MX to mail.<their-domain> unless you override with MAIL_MX_HOST (single hostname for all orgs).
# MAIL_MX_HOST=
# Server public IPv4 — dashboard shows exact A + SPF lines; set on production host .env
# MAIL_SEND_IP=
# Same IPv4 for branded custom-domain verification (A record must match). Falls back to MAIL_SEND_IP if unset.
# SERVER_IP=
# Optional: full DKIM TXT value to display in the dashboard (same public key as MAIL_DKIM_PRIVATE_KEY on apps/mail)
# MAIL_DKIM_DNS_VALUE=

# Webhooks (same value must be set for the mail service so it can sign inbound webhook payloads)
WEBHOOK_SECRET=
# Optional: shared secret for service log ingestion at POST /api/admin/logs/ingest.
# Set same value on mail service as LOG_INGEST_SECRET to include mail logs in Admin > System Logs.
# LOG_INGEST_SECRET=

# Platform org email (inbox + send). Set to false to disable for all orgs (users see a generic message).
# EMAIL_SYSTEM_ENABLED=true

# Amazon SES fallback (optional): after the in-repo mail app fails delivery, retry via SES for orgs with a verified SES domain identity.
# Requires AWS credentials (env vars, instance role, etc.) and AWS_REGION. Per-org domain must verify in SES; API syncs on Verify DNS / cron.
# EMAIL_SEND_FALLBACK_SES_ENABLED=true
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional: restrict fallback to org IDs (comma-separated). Empty = all orgs with email_ses_verified_at set.
# EMAIL_SEND_SES_ORG_IDS=
# Optional SES configuration set name for metrics / event publishing.
# SES_CONFIGURATION_SET=
# Optional: require From to be a normal address (already enforced by org domain in app).
# SES_FROM_STRICT=true

# Paystack
PAYSTACK_SECRET=

# Object storage (S3-compatible: MinIO or R2)
# MinIO (local/Docker): S3_ENDPOINT=http://localhost:9000, use MINIO_ROOT_* for keys
# R2: set S3_ENDPOINT to https://<ACCOUNT_ID>.r2.cloudflarestorage.com and R2 credentials as S3_* keys
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=luminum-storage
S3_REGION=us-east-1
# Public base URL for file links (e.g. https://api.example.com). If set, file URLs use /api/files/<key> under this base.
API_URL=

# Redis
REDIS_URL=
REDIS_PASSWORD=

# VAPID keys (push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics Go service URL (for form-notify and live-update)
ANALYTICS_URL=http://localhost:8080

# Public URL of this API server (for WebSocket URL returned to dashboard)
# If not set, defaults to http://localhost:4000
API_WS_URL=http://localhost:4000

# WhatsApp (whatsapp-web.js): path to Chromium when Puppeteer's bundled Chrome is missing (e.g. Docker).
# Set to /usr/bin/chromium or /usr/bin/chromium-browser. Dockerfile.api sets this for the image.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Protocol timeout for Puppeteer (ms). Default 600000. Increase if you see "callFunctionOn timed out".
# WHATSAPP_PROTOCOL_TIMEOUT_MS=600000
# Always-on reconnect: base delay (ms) and max backoff cap. Avoids hammering Puppeteer after crashes.
# WHATSAPP_ALWAYS_ON_RECONNECT_MS=5000
# WHATSAPP_ALWAYS_ON_MAX_BACKOFF_MS=1800000
# Admin incident log: min time between INIT_EXHAUSTED rows for the same org (ms). Default 600000.
# WHATSAPP_INIT_EXHAUSTED_LOG_COOLDOWN_MS=600000
# Do NOT set WHATSAPP_PUPPETEER_MINIMAL=true in production unless you must — it often causes unstable WhatsApp Web.
# WHATSAPP_PUPPETEER_MINIMAL=false
