# Express API Server
PORT=4000

# Public URL of the dashboard (for Better Auth baseURL, invite links, etc.)
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://...

# Better Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=

# Resend (email sending)
RESEND_API_KEY=

# In-repo mail service (apps/mail): base URL for send and health. In production set to http://mail:8025.
MAIL_APP_URL=http://mail:8025
# Optional: secret sent as X-Mail-Secret / Authorization to the mail app.
# MAIL_APP_SECRET=
# Default From header (e.g. Luminum <noreply@luminum.agency>).
# MAIL_FROM_DEFAULT=

# Org email DNS (MX check): expected host customers must point MX to.
# Optional: set MAIL_MX_DOMAIN (e.g. luminum.agency) to auto-discover from DNS; or we use the domain from MAIL_FROM_DEFAULT.
# MAIL_MX_HOST=
# MAIL_MX_DOMAIN=luminum.agency

# Webhooks (same value must be set for the mail service so it can sign inbound webhook payloads)
WEBHOOK_SECRET=

# Paystack
PAYSTACK_SECRET=

# Object storage (S3-compatible: MinIO or R2)
# MinIO (local/Docker): S3_ENDPOINT=http://localhost:9000, use MINIO_ROOT_* for keys
# R2: set S3_ENDPOINT to https://<ACCOUNT_ID>.r2.cloudflarestorage.com and R2 credentials as S3_* keys
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=luminum-storage
S3_REGION=us-east-1
# Public base URL for file links (e.g. https://api.example.com). If set, file URLs use /api/files/<key> under this base.
API_URL=

# Redis
REDIS_URL=
REDIS_PASSWORD=

# VAPID keys (push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics Go service URL (for form-notify and live-update)
ANALYTICS_URL=http://localhost:8080

# Public URL of this API server (for WebSocket URL returned to dashboard)
# If not set, defaults to http://localhost:4000
API_WS_URL=http://localhost:4000
