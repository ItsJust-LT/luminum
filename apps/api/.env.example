# Express API Server
PORT=4000

# Public URL of the dashboard (for Better Auth baseURL, invite links, etc.)
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://...

# Better Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BETTER_AUTH_SECRET=

# Resend (email sending)
RESEND_API_KEY=

# Webhooks
WEBHOOK_SECRET=

# Paystack
PAYSTACK_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis
REDIS_URL=
REDIS_PASSWORD=

# VAPID keys (push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics Go service URL (for form-notify and live-update)
ANALYTICS_URL=http://localhost:8080

# Public URL of this API server (for WebSocket URL returned to dashboard)
# If not set, defaults to http://localhost:4000
API_WS_URL=http://localhost:4000
