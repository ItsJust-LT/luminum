# Luminum blog + API (server). Copy to .env.local and fill in values.
# Website ID: UUID from the Luminum dashboard for this site.

LUMINUM_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: defaults to https://api.luminum.app
# LUMINUM_API_URL=https://api.luminum.app

# Public Website ID (required for analytics script + client form submits).
# Should match LUMINUM_WEBSITE_ID when both are set.
NEXT_PUBLIC_LUMINUM_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Luminum Go analytics base URL (tracking script + POST /form).
# Used by @itsjust-lt/website-kit AnalyticsScript and submitForm.
# Optional: defaults to https://analytics.luminum.app in website-kit
# NEXT_PUBLIC_LUMINUM_ANALYTICS_URL=https://analytics.luminum.app

# Optional: skip build-time Website ID check when using @itsjust-lt/website-kit/env helpers
# SKIP_LUMINUM_WEBSITE_ID_CHECK=1

# Vercel / CI: GitHub Packages auth for @itsjust-lt/* (must match .npmrc).
# Create a fine-grained PAT with read:packages and add as NODE_AUTH_TOKEN in the Vercel project.
# NODE_AUTH_TOKEN=ghp_...
