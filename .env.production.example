# =============================================================================
# Luminum production – app.luminum.agency / api / analytics
# =============================================================================
# Copy to .env on the server. Fill values from GitHub Secrets or your secret store.
# Postgres/Redis use internal defaults; override only if needed.
# =============================================================================

# Image prefix (replace YOUR_ORG with your GitHub org or username)
REGISTRY_IMAGE_PREFIX=ghcr.io/YOUR_ORG/luminum

# --- Public URLs (must match your domains) ---
APP_URL=https://app.luminum.agency
API_WS_URL=https://api.luminum.agency
NEXT_PUBLIC_APP_URL=https://app.luminum.agency
NEXT_PUBLIC_ANALYTICS_URL=https://analytics.luminum.agency

# --- Auth & webhooks (store in GitHub Secrets, set on server) ---
BETTER_AUTH_SECRET=
WEBHOOK_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Integrations (optional; add to GitHub Secrets if used) ---
RESEND_API_KEY=
PAYSTACK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Object storage (S3-compatible: MinIO or R2) ---
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=luminum-storage
S3_REGION=us-east-1
API_URL=https://api.luminum.agency
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
