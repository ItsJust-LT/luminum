 generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamp(6)
  refreshTokenExpiresAt DateTime? @db.Timestamp(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @db.Timestamp(6)
  updatedAt             DateTime  @db.Timestamp(6)
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model device_subscriptions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?
  device_id    String
  subscription Json
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  user_agent   String?
  user         user?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, device_id], map: "device_user_unique")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model events {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url             String?
  referrer        String?
  screen_size     String?
  ip              String?
  country         String?
  city            String?
  created_at      DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  website_id      String?   @db.Uuid
  session_id      String?
  duration        Int?
  device_type     String?
  user_id         String?   @db.VarChar(255)
  page_title      String?   @db.VarChar(500)
  referrer_domain String?   @db.VarChar(255)
  browser_name    String?   @db.VarChar(50)
  browser_version String?   @db.VarChar(20)
  os_name         String?   @db.VarChar(50)
  os_version      String?   @db.VarChar(20)
  url_params      Json?
  referrer_path   String?
  traffic_source  String?   @db.VarChar(50)
  user_agent      String?
  utm_params      Json?
  websites        websites? @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([website_id], map: "idx_events_website_id")
  @@index([session_id], map: "idx_events_session_id")
  @@index([browser_name], map: "idx_events_browser_name")
  @@index([os_name], map: "idx_events_os_name")
  @@index([referrer_domain], map: "idx_events_referrer_domain")
  @@index([traffic_source], map: "idx_events_traffic_source")
  @@index([user_id], map: "idx_events_user_id")
  @@index([utm_params], map: "idx_events_utm_params", type: Gin)
}

model form_submissions {
  website_id   String    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submitted_at DateTime  @default(now()) @db.Timestamptz(6)
  data         Json
  seen         Boolean   @default(false)
  contacted    Boolean   @default(false)
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id   String?   // Same __luminum_sid as analytics; empty when unknown
  websites     websites  @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([website_id], map: "idx_form_submissions_website_id")
  @@index([session_id], map: "idx_form_submissions_session_id")
}

model images {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  name            String        @db.VarChar
  url             String
  organization_id String?
  size_bytes      BigInt?       @default(0)
  organization    organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model invitation {
  id             String       @id
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime     @db.Timestamp(6)
  inviterId      String?
  createdAt      DateTime     @db.Timestamptz(6)
  user           user?        @relation(fields: [inviterId], references: [id], onUpdate: NoAction)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime @db.Timestamptz(6)
}

model member {
  id             String       @id
  organizationId String
  userId         String
  role           String
  createdAt      DateTime     @db.Timestamp(6)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           user         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?
  type       String
  title      String?
  message    String?
  data       Json?
  read       Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user       user?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at])
}

model notification_preferences {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @unique
  push_enabled     Boolean   @default(true)
  in_app_enabled   Boolean   @default(true)
  email_enabled    Boolean   @default(true)
  disabled_types   Json?     @db.JsonB // Array of notification types to disable
  quiet_hours_start String?  @db.VarChar(5) // Format: "HH:MM" in 24h format
  quiet_hours_end  String?   @db.VarChar(5) // Format: "HH:MM" in 24h format
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  user             user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model email {
  id              String       @id @default(cuid())
  organization_id String?      @db.VarChar(255)
  from            String?
  to              String?
  subject         String?
  text            String?      @db.Text
  html            String?      @db.Text
  headers         Json?
  receivedAt      DateTime?
  read            Boolean      @default(false)
  messageId       String?      @unique // RFC Message-ID for deduplication (normalized: trimmed, lowercased)
  dedupeKey       String?      @unique // Fallback dedupe when Message-ID absent: hash(org+from+to+subject+receivedAt)
  contentHash     String?      @unique // Content-based dedupe: md5(org+from+to+subject+text+html) — same as dedup script
  direction       String       @default("inbound") @db.VarChar(20) // "inbound" | "outbound"
  in_reply_to     String?      @db.Text
  references      String?      @db.Text
  sent_at         DateTime?    @db.Timestamptz(6)
  attachments     attachment[]
  createdAt       DateTime     @default(now())
  organization    organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organization_id])
  @@index([receivedAt])
  @@index([subject])
  @@index([from])
  @@index([read])
  @@index([direction])
  @@map("email")
}

/// Cache of avatar image URL per sender email (BIMI/Gravatar). Populated by getAvatarForEmail and email webhook.
model email_avatar_cache {
  email       String    @id // normalized: trim + lowercase
  avatar_url  String?   @db.Text
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("email_avatar_cache")
}

model attachment {
  id        String  @id @default(cuid())
  emailId   String
  filename  String
  contentType String
  size      Int?
  r2Key     String
  url       String? // optional public URL or proxied URL
  email     email   @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("attachment")
}

model organization {
  id                                                                String                    @id
  name                                                              String
  slug                                                              String                    @unique
  logo                                                              String?
  createdAt                                                         DateTime                  @db.Timestamp(6)
  metadata                                                          String?
  currency                                                          String                    @default("ZAR") @db.VarChar
  country                                                           String                    @default("South Africa") @db.VarChar
  payment_provider                                                  String                    @default("paystack") @db.VarChar
  subscription_status                                               String?                   @default("active") @db.VarChar(50)
  primary_subscription_id                                           String?
  max_subscriptions                                                 Int?                      @default(1)
  billing_email                                                     String?                   @db.VarChar(255)
  tax_id                                                            String?                   @db.VarChar(100)
  billing_address                                                   Json?
  max_storage_bytes                                                 BigInt?                   @default(10737418240)
  used_storage_bytes                                                BigInt?                   @default(0)
  emails_enabled                                                    Boolean                   @default(false)
  email_domain_id                                                   String?                   @db.Uuid
  email_dns_verified_at                                             DateTime?                 @db.Timestamptz(6)
  email_dns_last_check_at                                           DateTime?                 @db.Timestamptz(6)
  email_dns_last_error                                              String?                   @db.Text
  email_from_address                                                String?                   @db.VarChar(255)
  whatsapp_enabled                                                  Boolean                   @default(false)
  whatsapp_always_on                                                Boolean                   @default(false)
  analytics_enabled                                                 Boolean                   @default(false)
  blogs_enabled                                                    Boolean                   @default(false)
  emails                                                            email[]
  images                                                            images[]
  invitations                                                       invitation[]
  members                                                           member[]
  subscriptions_organization_primary_subscription_idTosubscriptions subscriptions?            @relation("organization_primary_subscription_idTosubscriptions", fields: [primary_subscription_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions_subscriptions_organization_idToorganization         subscriptions[]           @relation("subscriptions_organization_idToorganization")
  support_tickets                                                   support_tickets[]
  websites                                                          websites[]
  email_domain                                                      websites?                 @relation("OrganizationEmailDomain", fields: [email_domain_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  whatsapp_accounts                                                 whatsapp_account[]
  whatsapp_analytics                                                whatsapp_analytics_daily[]
  blog_posts                                                        blog_post[]
  blog_assets                                                       blog_asset[]
  blog_preview_tokens                                               blog_preview_token[]

  @@index([payment_provider], map: "idx_organization_payment_provider")
  @@index([email_domain_id], map: "idx_organization_email_domain_id")
  @@index([primary_subscription_id], map: "idx_organization_primary_subscription")
  @@index([subscription_status], map: "idx_organization_subscription_status")
}

model payments {
  id                      String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  subscription_id         String
  provider                String        @db.VarChar(50)
  provider_payment_id     String?
  provider_transaction_id String?
  amount                  Decimal       @db.Decimal(10, 2)
  currency                String        @db.VarChar(3)
  status                  String        @db.VarChar(50)
  payment_method          String?       @db.VarChar(100)
  paid_at                 DateTime?     @db.Timestamp(6)
  created_at              DateTime      @default(now()) @db.Timestamp(6)
  metadata                Json?
  subscriptions           subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([provider], map: "idx_payments_provider")
  @@index([status], map: "idx_payments_status")
  @@index([subscription_id], map: "idx_payments_subscription_id")
}

model session {
  id                   String   @id
  expiresAt            DateTime @db.Timestamp(6)
  token                String   @unique
  createdAt            DateTime @db.Timestamp(6)
  updatedAt            DateTime @db.Timestamp(6)
  ipAddress            String?
  userAgent            String?
  userId               String
  impersonatedBy       String?
  activeOrganizationId String?
  user                 user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model subscriptions {
  id                                                               String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  organization_id                                                  String
  provider                                                         String         @default("paystack") @db.VarChar(50)
  provider_subscription_id                                         String?
  provider_customer_id                                             String?
  plan_name                                                        String?        @db.VarChar(255)
  plan_id                                                          String?
  status                                                           String         @default("active") @db.VarChar(50)
  type                                                             String         @default("paid") @db.VarChar(50)
  amount                                                           Decimal?       @db.Decimal(10, 2)
  currency                                                         String         @default("ZAR") @db.VarChar(3)
  billing_cycle                                                    String?        @db.VarChar(20)
  trial_start_date                                                 DateTime?      @db.Timestamp(6)
  trial_end_date                                                   DateTime?      @db.Timestamp(6)
  current_period_start                                             DateTime?      @db.Timestamp(6)
  current_period_end                                               DateTime?      @db.Timestamp(6)
  canceled_at                                                      DateTime?      @db.Timestamp(6)
  created_at                                                       DateTime       @default(now()) @db.Timestamp(6)
  updated_at                                                       DateTime       @default(now()) @db.Timestamp(6)
  metadata                                                         Json?
  organization_organization_primary_subscription_idTosubscriptions organization[] @relation("organization_primary_subscription_idTosubscriptions")
  payments                                                         payments[]
  organization_subscriptions_organization_idToorganization         organization   @relation("subscriptions_organization_idToorganization", fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organization_id], map: "idx_subscriptions_organization_id")
  @@index([provider], map: "idx_subscriptions_provider")
  @@index([status], map: "idx_subscriptions_status")
  @@index([type], map: "idx_subscriptions_type")
}

model support_attachments {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id            String            @db.Uuid
  message_id           String?           @db.Uuid
  uploaded_by          String
  filename             String            @db.VarChar(255)
  original_filename    String            @db.VarChar(255)
  file_size            Int
  mime_type            String            @db.VarChar(100)
  cloudinary_public_id String            @db.VarChar(255)
  cloudinary_url       String
  storage_key          String?           @db.VarChar(512)
  created_at           DateTime?         @default(now()) @db.Timestamptz(6)
  support_messages     support_messages? @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  support_tickets      support_tickets   @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                 user              @relation(fields: [uploaded_by], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([message_id], map: "idx_support_attachments_message_id")
  @@index([ticket_id], map: "idx_support_attachments_ticket_id")
  @@index([storage_key], map: "idx_support_attachments_storage_key")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model support_messages {
  id                                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id                             String                @db.Uuid
  sender_id                             String
  message                               String
  message_type                          String?               @default("text") @db.VarChar(20)
  attachments                           Json?                 @default("[]")
  is_read                               Boolean?              @default(false)
  read_at                               DateTime?             @db.Timestamptz(6)
  read_by                               String?
  created_at                            DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?             @default(now()) @db.Timestamptz(6)
  support_attachments                   support_attachments[]
  user_support_messages_read_byTouser   user?                 @relation("support_messages_read_byTouser", fields: [read_by], references: [id], onUpdate: NoAction)
  user_support_messages_sender_idTouser user                  @relation("support_messages_sender_idTouser", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  support_tickets                       support_tickets       @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_support_messages_created_at")
  @@index([sender_id], map: "idx_support_messages_sender_id")
  @@index([ticket_id], map: "idx_support_messages_ticket_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model support_ticket_participants {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id       String          @db.Uuid
  user_id         String
  role            String          @db.VarChar(20)
  joined_at       DateTime?       @default(now()) @db.Timestamptz(6)
  support_tickets support_tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            user            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ticket_id, user_id])
  @@index([ticket_id], map: "idx_support_ticket_participants_ticket_id")
  @@index([user_id], map: "idx_support_ticket_participants_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model support_tickets {
  id                                     String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_number                          String                        @unique @db.VarChar(20)
  title                                  String                        @db.VarChar(255)
  description                            String
  status                                 String?                       @default("open") @db.VarChar(20)
  priority                               String?                       @default("medium") @db.VarChar(10)
  category                               String?                       @default("general") @db.VarChar(50)
  user_id                                String?
  organization_id                        String?
  assigned_to                            String?
  assigned_at                            DateTime?                     @db.Timestamptz(6)
  created_at                             DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?                     @default(now()) @db.Timestamptz(6)
  resolved_at                            DateTime?                     @db.Timestamptz(6)
  closed_at                              DateTime?                     @db.Timestamptz(6)
  metadata                               Json?                         @default("{}")
  support_attachments                    support_attachments[]
  support_messages                       support_messages[]
  support_ticket_participants            support_ticket_participants[]
  user_support_tickets_assigned_toTouser user?                         @relation("support_tickets_assigned_toTouser", fields: [assigned_to], references: [id], onUpdate: NoAction)
  organization                           organization?                 @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_support_tickets_user_idTouser     user?                         @relation("support_tickets_user_idTouser", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assigned_to], map: "idx_support_tickets_assigned_to")
  @@index([created_at], map: "idx_support_tickets_created_at")
  @@index([organization_id], map: "idx_support_tickets_organization_id")
  @@index([priority], map: "idx_support_tickets_priority")
  @@index([status], map: "idx_support_tickets_status")
  @@index([user_id], map: "idx_support_tickets_user_id")
}

model user {
  id                                                String                        @id
  name                                              String
  email                                             String                        @unique
  emailVerified                                     Boolean
  image                                             String?
  createdAt                                         DateTime                      @db.Timestamp(6)
  updatedAt                                         DateTime                      @db.Timestamp(6)
  role                                              String?
  banned                                            Boolean?
  banReason                                         String?
  banExpires                                        DateTime?                     @db.Timestamp(6)
  lastSeenAt                                        DateTime?                     @db.Timestamp(6)
  accounts                                          account[]
  dashboard_activity                                dashboard_activity[]
  device_subscriptions                              device_subscriptions[]
  invitation                                        invitation[]
  member                                            member[]
  notification_preferences                          notification_preferences?
  notifications                                     notifications[]
  session                                           session[]
  support_attachments                               support_attachments[]
  support_messages_support_messages_read_byTouser   support_messages[]            @relation("support_messages_read_byTouser")
  support_messages_support_messages_sender_idTouser support_messages[]            @relation("support_messages_sender_idTouser")
  support_ticket_participants                       support_ticket_participants[]
  support_tickets_support_tickets_assigned_toTouser support_tickets[]             @relation("support_tickets_assigned_toTouser")
  support_tickets_support_tickets_user_idTouser     support_tickets[]             @relation("support_tickets_user_idTouser")
}

model dashboard_activity {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String
  session_start DateTime  @db.Timestamp(6)
  session_end   DateTime? @db.Timestamp(6)
  duration_ms   Int       @default(0)
  date          DateTime  @db.Date
  user          user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, date])
}

model page_transitions {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  website_id    String    @db.Uuid
  session_id    String
  from_page     String    @db.VarChar(2048)
  to_page       String    @db.VarChar(2048)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  websites      websites  @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([website_id, created_at])
  @@index([website_id, from_page, to_page])
  @@index([session_id])
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @db.Timestamp(6)
  createdAt  DateTime? @db.Timestamp(6)
  updatedAt  DateTime? @db.Timestamp(6)
}

model server_metrics {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  hostname                String?   @db.VarChar(255)
  platform                String?   @db.VarChar(64)
  node_version            String?   @db.VarChar(32)
  cpu_usage_percent       Float?
  cpu_cores               Int?
  memory_used_bytes       BigInt?
  memory_total_bytes      BigInt?
  memory_usage_percent    Float?
  process_heap_used_bytes BigInt?
  process_heap_total_bytes BigInt?
  process_rss_bytes       BigInt?
  system_uptime_seconds    Float?
  process_uptime_seconds  Float?
  load_avg_1m             Float?
  load_avg_5m             Float?
  load_avg_15m            Float?
  disk_used_bytes         BigInt?
  disk_total_bytes        BigInt?
  disk_usage_percent      Float?

  @@index([created_at], map: "idx_server_metrics_created_at")
}

model system_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  service    String   @db.VarChar(64)
  level      String   @db.VarChar(16)
  message    String   @db.Text
  meta       Json?
  request_id String?  @db.VarChar(64)

  @@index([created_at], map: "idx_system_logs_created_at")
  @@index([service], map: "idx_system_logs_service")
  @@index([level], map: "idx_system_logs_level")
}

// Ably LiveSync tables
model outbox {
  sequence_id  Int       @id @default(autoincrement())
  mutation_id  String
  channel      String
  name         String
  rejected     Boolean   @default(false)
  data         Json?
  headers      Json?
  locked_by    String?
  lock_expiry  DateTime? @db.Timestamp(6)
  processed    Boolean   @default(false)

  @@index([channel])
  @@index([processed])
  @@map("outbox")
}

model nodes {
  id     String    @id
  expiry DateTime  @db.Timestamp(6)

  @@map("nodes")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model websites {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String?              @db.VarChar(255)
  domain             String               @unique @db.VarChar(255)
  organization_id    String               @db.VarChar(255)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  analytics          Boolean?             @default(false)
  script_last_verified_at           DateTime?            @db.Timestamptz(6)
  script_last_error                String?              @db.Text
  metadata           Json?
  website_id         String?              @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settings           Json?                @default("{}")
  events                     events[]
  form_submissions           form_submissions[]
  page_transitions           page_transitions[]
  organization               organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization_email_domain   organization[]       @relation("OrganizationEmailDomain")

  @@index([domain], map: "idx_websites_domain")
  @@index([metadata], map: "idx_websites_metadata_gin", type: Gin)
  @@index([organization_id], map: "idx_websites_organization_id")
  @@index([website_id], map: "idx_websites_website_id")
}

// ── Blog (per-organization posts, MDX-like content, private assets) ─────

enum BlogPostStatus {
  draft
  published
}

model blog_post {
  id                    String         @id @default(cuid())
  organization_id       String
  slug                  String         @db.VarChar(255)
  title                 String         @db.VarChar(500)
  summary               String?        @db.Text
  content_markdown      String         @db.Text
  content_render_spec   Json?
  cover_image_key       String         @db.Text
  status                BlogPostStatus @default(draft)
  published_at          DateTime?      @db.Timestamptz(6)
  seo_title             String?        @db.VarChar(500)
  seo_description       String?        @db.Text
  categories            Json?          @db.JsonB
  created_at            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime       @updatedAt @db.Timestamptz(6)
  organization          organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  blog_assets           blog_asset[]

  @@unique([organization_id, slug])
  @@index([organization_id])
  @@index([organization_id, status])
  @@index([published_at])
  @@index([categories], type: Gin)
}

model blog_asset {
  id                 String       @id @default(cuid())
  organization_id    String
  blog_post_id       String?
  type               String       @db.VarChar(20)
  s3_key             String       @db.Text
  mime               String       @db.VarChar(255)
  size_bytes         Int          @default(0)
  original_filename  String       @db.VarChar(500)
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  organization       organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  blog_post          blog_post?   @relation(fields: [blog_post_id], references: [id], onDelete: SetNull)

  @@unique([organization_id, s3_key])
  @@index([organization_id])
  @@index([s3_key])
  @@index([blog_post_id])
}

model blog_preview_token {
  id              String    @id @default(cuid())
  organization_id String
  token           String    @unique @default(cuid())
  expires_at      DateTime  @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  organization    organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([token])
  @@index([expires_at])
}

// ── WhatsApp Integration ────────────────────────────────────────────────

enum WhatsappAccountStatus {
  DISCONNECTED
  CONNECTING
  QR_PENDING
  CONNECTED
  ERROR
}

model whatsapp_account {
  id                String                @id @default(cuid())
  organization_id   String                @db.VarChar(255)
  phone_number      String                @db.VarChar(20)
  status            WhatsappAccountStatus @default(DISCONNECTED)
  session_data      Bytes?                @db.ByteA
  qr_code           String?               @db.Text
  qr_updated_at     DateTime?             @db.Timestamptz(6)
  last_error        String?               @db.Text
  connected_at      DateTime?             @db.Timestamptz(6)
  last_seen_at      DateTime?             @db.Timestamptz(6)
  session_saved_at  DateTime?             @db.Timestamptz(6)
  retry_count       Int                   @default(0)
  next_retry_at     DateTime?             @db.Timestamptz(6)
  owner_instance_id String?               @db.VarChar(255)
  owner_heartbeat_at DateTime?            @db.Timestamptz(6)
  lease_expires_at  DateTime?             @db.Timestamptz(6)
  created_at        DateTime              @default(now()) @db.Timestamptz(6)
  updated_at        DateTime              @updatedAt @db.Timestamptz(6)
  organization      organization          @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id])
  @@index([organization_id])
  @@index([status])
}

// Chat and message data is now stored in Redis only (7-day TTL, in-memory).
// Analytics aggregates are persisted here for admin reporting.

model whatsapp_analytics_daily {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String       @db.VarChar(255)
  day               DateTime     @db.Date
  messages_sent     Int          @default(0)
  messages_received Int          @default(0)
  media_sent        Int          @default(0)
  media_received    Int          @default(0)
  created_at        DateTime     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  organization      organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, day])
  @@index([organization_id])
  @@index([day])
}
