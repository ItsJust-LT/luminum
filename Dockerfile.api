# Build API from monorepo root (needs workspace deps)
FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate
WORKDIR /app

FROM base AS builder
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY apps/api ./apps/api
# Use copy so node_modules can be copied between stages (no broken symlinks)
RUN echo "package-import-method=copy" > .npmrc
RUN pnpm install --frozen-lockfile
ENV DATABASE_URL=postgresql://build:build@localhost:5432/build
RUN pnpm run build --filter=@luminum/database --filter=@luminum/api
# Flatten node_modules (resolve any symlinks) so COPY to runner has real files
RUN cp -rL /app/node_modules /app/node_modules_flat

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/apps/api/dist ./dist
COPY --from=builder /app/apps/api/package.json ./
COPY --from=builder /app/node_modules_flat ./node_modules
COPY --from=builder /app/packages/database ./packages/database
RUN mkdir -p /app/packages/database/prisma/migrations
# Ensure dotenv present (npm install fails here due to workspace:* in package.json)
RUN cd /tmp && npm init -y && npm install dotenv && cp -r node_modules/dotenv /app/node_modules/
COPY docker/entrypoint-api.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
EXPOSE 4000
ENTRYPOINT ["/entrypoint.sh"]
CMD ["node", "dist/index.js"]
